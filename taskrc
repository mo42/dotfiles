data.location=~/.config/task
include /usr/share/doc/task/rc/dark-256.theme
include ~/dotfiles/task.theme
rc.dateformat=y-m-d h:n
weekstart=Monday
displayweeknumber=yes
calendar.holidays=none
locking=on

urgency.next.coefficient      =  12.0
urgency.waiting.coefficient   = -10.0
urgency.scheduled.coefficient =  2.0
urgency.blocked.coefficient   = -12.0
urgency.due.coefficient       =  16.0

report.next.columns           = id,depends,priority,project,tags,recur,scheduled.countdown,due,due.relative,until.remaining,description,urgency
report.next.description       = Most urgent tasks
report.next.filter            = status:pending limit:page
report.next.labels            = ID,Deps,P,Project,Tag,Recur,S,Due Date,Due,Until,Description,Urg
report.next.sort              = urgency-

report.ready.columns          = id,project,tags,due.relative,description
report.ready.labels           = ID,Project,Tags,Due,Description
report.ready.sort             = urgency-
